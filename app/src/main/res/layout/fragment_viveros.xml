<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F0F4ED">

    <!-- HEADER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#3A7D44"
        android:orientation="vertical"
        android:padding="16dp"
        android:paddingBottom="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Córdoba"
            android:textSize="13sp"
            android:textColor="#B8D4BC"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Viveros cercanos"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="14dp"/>

        <!-- BUSCADOR -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="44dp"
            app:cardCornerRadius="10dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#33FFFFFF"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="12dp"
                android:paddingEnd="12dp">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@android:drawable/ic_menu_search"
                    app:tint="#B8D4BC"
                    android:layout_marginEnd="8dp"/>

                <EditText
                    android:id="@+id/etBuscarVivero"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:hint="Buscar vivero o planta..."
                    android:textColorHint="#B8D4BC"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:background="@null"
                    android:inputType="text"
                    android:imeOptions="actionSearch"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

    <!-- MAPA PLACEHOLDER -->
    <FrameLayout
        android:id="@+id/frameMapaViveros"
        android:layout_width="match_parent"
        android:layout_height="160dp"
        android:background="#D8EAD0">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="🗺️ Mapa próximamente"
            android:textSize="13sp"
            android:textColor="#3A7D44"/>

    </FrameLayout>

    <!-- CANTIDAD -->
    <TextView
        android:id="@+id/tvCantidadViveros"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Viveros encontrados cerca tuyo"
        android:textSize="12sp"
        android:textColor="#888888"
        android:layout_marginStart="16dp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="8dp"/>

    <!-- LISTA VIVEROS -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvViveros"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="12dp"
        android:clipToPadding="false"/>

</LinearLayout>