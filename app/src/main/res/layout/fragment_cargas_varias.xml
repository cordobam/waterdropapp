<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F0F4ED">

    <!-- HEADER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#3A7D44"
        android:padding="20dp"
        android:paddingBottom="16dp">

        <TextView
            android:id="@+id/tvTituloCargas"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Cargas varias"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Agregá plantas o grupos nuevos"
            android:textSize="13sp"
            android:textColor="#B8D4BC"
            android:layout_marginTop="2dp"/>

    </LinearLayout>

    <!-- TABS -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayoutCargas"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        app:tabIndicatorColor="#3A7D44"
        app:tabTextColor="#888888"
        app:tabSelectedTextColor="#3A7D44"
        app:tabIndicatorFullWidth="false"
        app:tabRippleColor="@null"
        app:tabMode="fixed">

        <com.google.android.material.tabs.TabItem
            android:text="Cargar plantas"/>

        <com.google.android.material.tabs.TabItem
            android:text="Cargar grupos"/>

    </com.google.android.material.tabs.TabLayout>

    <!-- VIEWPAGER -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPagerCarga"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

</LinearLayout>