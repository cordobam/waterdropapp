<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F4ED"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- HEADER VERDE -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#3A7D44"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="20dp"
            android:paddingTop="40dp"
            android:paddingBottom="48dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="64dp"
                android:layout_height="64dp"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp"
                app:strokeColor="#55FFFFFF"
                app:strokeWidth="1dp"
                android:layout_marginBottom="16dp">
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="#33FFFFFF">
                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_marketplace"
                        app:tint="#FFFFFF"/>
                </FrameLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Marketplace"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Comprá, vendé e intercambiá plantas"
                android:textSize="13sp"
                android:textColor="#B8D4BC"
                android:layout_marginTop="4dp"/>

        </LinearLayout>

        <!-- CARD FORMULARIO -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="-16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeColor="#C8DFC0"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Ingresá a tu cuenta"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#1A3A1F"
                    android:gravity="center"
                    android:layout_marginBottom="16dp"/>

                <!-- EMAIL -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Email"
                    android:textSize="12sp"
                    android:textColor="#888888"
                    android:layout_marginStart="6dp"
                    android:layout_marginBottom="5dp"/>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:boxCornerRadiusTopStart="10dp"
                    app:boxCornerRadiusTopEnd="10dp"
                    app:boxCornerRadiusBottomStart="10dp"
                    app:boxCornerRadiusBottomEnd="10dp"
                    app:boxStrokeColor="#C8DFC0"
                    app:boxBackgroundColor="#F0F4ED"
                    app:startIconDrawable="@android:drawable/ic_dialog_email"
                    app:startIconTint="#3A7D44">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etEmail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="tu@email.com"
                        android:inputType="textEmailAddress"
                        android:textSize="13sp"/>
                </com.google.android.material.textfield.TextInputLayout>

                <!-- CONTRASEÑA -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Contraseña"
                    android:textSize="12sp"
                    android:textColor="#888888"
                    android:layout_marginStart="6dp"
                    android:layout_marginBottom="5dp"/>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:boxCornerRadiusTopStart="10dp"
                    app:boxCornerRadiusTopEnd="10dp"
                    app:boxCornerRadiusBottomStart="10dp"
                    app:boxCornerRadiusBottomEnd="10dp"
                    app:boxStrokeColor="#C8DFC0"
                    app:boxBackgroundColor="#F0F4ED"
                    app:startIconDrawable="@android:drawable/ic_lock_lock"
                    app:startIconTint="#3A7D44"
                    app:endIconMode="password_toggle">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etPassword"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="••••••••"
                        android:inputType="textPassword"
                        android:textSize="13sp"/>
                </com.google.android.material.textfield.TextInputLayout>

                <!-- OLVIDASTE CONTRASEÑA -->
                <TextView
                    android:id="@+id/tvOlvidePassword"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="¿Olvidaste tu contraseña?"
                    android:textSize="12sp"
                    android:textColor="#3A7D44"
                    android:gravity="end"
                    android:layout_marginTop="6dp"
                    android:layout_marginBottom="18dp"/>

                <!-- BOTON INGRESAR -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnIngresar"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Ingresar"
                    android:textSize="14sp"
                    android:textColor="#FFFFFF"
                    app:backgroundTint="#3A7D44"
                    app:cornerRadius="10dp"
                    android:layout_marginBottom="12dp"/>

                <!-- SEPARADOR -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">
                    <View android:layout_width="0dp" android:layout_height="0.5dp"
                        android:layout_weight="1" android:background="#C8DFC0"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="o continuá con" android:textSize="12sp"
                        android:textColor="#AAAAAA" android:layout_marginStart="10dp"
                        android:layout_marginEnd="10dp"/>
                    <View android:layout_width="0dp" android:layout_height="0.5dp"
                        android:layout_weight="1" android:background="#C8DFC0"/>
                </LinearLayout>

                <!-- BOTONES SOCIALES -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="18dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnGoogle"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:text="Google"
                        android:textSize="13sp"
                        android:textColor="#1A3A1F"
                        app:strokeColor="#C8DFC0"
                        app:cornerRadius="10dp"
                        app:backgroundTint="#F0F4ED"
                        app:icon="@drawable/ic_google"
                        app:iconSize="16dp"
                        app:iconPadding="6dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnApple"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:text="Apple"
                        android:textSize="13sp"
                        android:textColor="#1A3A1F"
                        app:strokeColor="#C8DFC0"
                        app:cornerRadius="10dp"
                        app:backgroundTint="#F0F4ED"
                        app:icon="@drawable/ic_apple"
                        app:iconSize="16dp"
                        app:iconPadding="6dp"/>

                </LinearLayout>

                <!-- REGISTRARSE -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:paddingTop="14dp"
                    android:background="@drawable/border_top_gray">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="¿No tenés cuenta? "
                        android:textSize="13sp"
                        android:textColor="#888888"/>

                    <TextView
                        android:id="@+id/tvRegistrate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Registrate"
                        android:textSize="13sp"
                        android:textColor="#3A7D44"
                        android:textStyle="bold"/>
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- EXPLORAR SIN CUENTA -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Podés ver viveros sin iniciar sesión"
                android:textSize="11sp"
                android:textColor="#AAAAAA"/>

            <TextView
                android:id="@+id/tvExplorarSinCuenta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Explorar sin cuenta →"
                android:textSize="12sp"
                android:textColor="#3A7D44"
                android:layout_marginTop="6dp"/>

        </LinearLayout>

    </LinearLayout>
</ScrollView>