<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="0dp"
    app:strokeColor="#C8DFC0"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#FFFFFF"
        android:padding="12dp"
        android:gravity="center_vertical">

        <!-- LOGO VIVERO -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_marginEnd="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:strokeColor="#C8DFC0"
            app:strokeWidth="1dp">

            <ImageView
                android:id="@+id/imgVivero"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/ic_planta"
                android:scaleType="centerCrop"
                android:background="#EAF3DE"
                app:tint="#3A7D44"/>

        </com.google.android.material.card.MaterialCardView>

        <!-- INFO -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- NOMBRE Y RATING -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvNombreVivero"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Nombre vivero"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#1A3A1F"
                    android:maxLines="1"
                    android:ellipsize="end"/>

                <TextView
                    android:id="@+id/tvRating"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⭐ 4.7"
                    android:textSize="12sp"
                    android:textColor="#1A3A1F"
                    android:textStyle="bold"/>

            </LinearLayout>

            <!-- DISTANCIA -->
            <TextView
                android:id="@+id/tvDistanciaVivero"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Barrio · 0.8 km"
                android:textSize="12sp"
                android:textColor="#888888"
                android:layout_marginTop="2dp"/>

            <!-- ESPECIALIDADES -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:layout_marginTop="6dp">

                <LinearLayout
                    android:id="@+id/layoutEspecialidades"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"/>

            </HorizontalScrollView>

            <!-- ESTADO ABIERTO/CERRADO Y BOTON -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="8dp">

                <View
                    android:id="@+id/indicadorEstado"
                    android:layout_width="7dp"
                    android:layout_height="7dp"
                    android:background="@drawable/bg_circle_green_light"
                    android:layout_marginEnd="5dp"/>

                <TextView
                    android:id="@+id/tvEstadoVivero"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Abierto · cierra 19:00"
                    android:textSize="11sp"
                    android:textColor="#3A7D44"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnVerVivero"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:text="Ver"
                    android:textSize="11sp"
                    android:textColor="#FFFFFF"
                    app:backgroundTint="#3A7D44"
                    app:cornerRadius="8dp"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"/>

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>