<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F0F4ED">

    <!-- HEADER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#3A7D44"
        android:orientation="vertical"
        android:padding="16dp"
        android:paddingBottom="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Explorá y comprá"
            android:textSize="13sp"
            android:textColor="#B8D4BC"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Marketplace"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="14dp"/>

        <!-- BUSCADOR -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="44dp"
            app:cardCornerRadius="10dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#33FFFFFF"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="12dp"
                android:paddingEnd="12dp">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@android:drawable/ic_menu_search"
                    app:tint="#B8D4BC"
                    android:layout_marginEnd="8dp"/>

                <EditText
                    android:id="@+id/etBuscar"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:hint="Buscar plantas, semillas..."
                    android:textColorHint="#B8D4BC"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:background="@null"
                    android:inputType="text"
                    android:imeOptions="actionSearch"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

    <!-- FILTROS -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="4dp">

        <LinearLayout
            android:id="@+id/layoutFiltros"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipTodos"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Todos"
                android:layout_marginEnd="8dp"
                style="@style/Widget.Material3.Chip.Filter"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/chipPlantas"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Plantas"
                android:layout_marginEnd="8dp"
                style="@style/Widget.Material3.Chip.Filter"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/chipSemillas"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Semillas"
                android:layout_marginEnd="8dp"
                style="@style/Widget.Material3.Chip.Filter"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/chipEsquejes"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Esquejes"
                android:layout_marginEnd="8dp"
                style="@style/Widget.Material3.Chip.Filter"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/chipTrueque"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Trueque"
                style="@style/Widget.Material3.Chip.Filter"/>

        </LinearLayout>
    </HorizontalScrollView>

    <!-- SUBTÍTULO -->
    <TextView
        android:id="@+id/tvCercaTuyo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Cerca tuyo · Córdoba"
        android:textSize="12sp"
        android:textColor="#888888"
        android:layout_marginStart="16dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"/>

    <!-- LISTA DE PUBLICACIONES -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvPublicaciones"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingBottom="12dp"
        android:clipToPadding="false"/>

    <!-- BOTON PUBLICAR -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnPublicar"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_margin="16dp"
        android:text="+ Publicar planta o semilla"
        android:textSize="14sp"
        android:textColor="#FFFFFF"
        app:backgroundTint="#3A7D44"
        app:cornerRadius="12dp"/>

</LinearLayout>