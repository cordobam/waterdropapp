<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    app:cardElevation="0dp"
    app:cardCornerRadius="16dp"
    app:strokeColor="#C8DFC0"
    app:strokeWidth="1dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <!-- Imagen -->
        <ImageView
            android:id="@+id/imgGrupo"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:src="@drawable/ic_grupo"
            android:scaleType="centerCrop"
            android:background="@drawable/bg_circle_green_light"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

        <!-- Nombre + cant plantas -->
        <TextView
            android:id="@+id/tvNombreGrupo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="Grupo"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#1A3A1F"
            app:layout_constraintStart_toEndOf="@id/imgGrupo"
            app:layout_constraintTop_toTopOf="@id/imgGrupo"
            app:layout_constraintEnd_toStartOf="@id/btnRegarGrupo"/>

        <TextView
            android:id="@+id/tvCantPlantas"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginTop="4dp"
            android:textSize="11sp"
            android:textColor="#888888"
            android:background="@drawable/bg_badge_grupo"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            app:layout_constraintStart_toEndOf="@id/imgGrupo"
            app:layout_constraintTop_toBottomOf="@id/tvNombreGrupo"
            app:layout_constraintEnd_toStartOf="@id/btnRegarGrupo"
            app:layout_constraintWidth_default="wrap"/>

        <!-- BTN REGAR — acción primaria -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRegarGrupo"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Regar"
            android:textSize="12sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#3A7D44"
            app:cornerRadius="10dp"
            android:layout_marginEnd="6dp"
            app:layout_constraintEnd_toStartOf="@id/btnVerGrupo"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

        <!-- BTN VER — acción secundaria -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnVerGrupo"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="36dp"
            android:layout_height="36dp"
            app:icon="@android:drawable/ic_menu_view"
            app:iconSize="18dp"
            app:iconTint="#3A7D44"
            app:strokeColor="#C8DFC0"
            app:strokeWidth="1.5dp"
            app:cornerRadius="10dp"
            app:iconPadding="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>