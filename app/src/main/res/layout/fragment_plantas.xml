<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#F0F4ED"
        android:paddingBottom="80dp">

        <!-- HEADER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#3A7D44"
            android:padding="20dp"
            android:paddingBottom="16dp">

            <TextView
                android:id="@+id/tvPromedio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Regar Plantas"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Revisá el estado de tus plantas"
                android:textSize="13sp"
                android:textColor="#B8D4BC"
                android:layout_marginTop="2dp"/>

        </LinearLayout>

        <!-- TABS -->
        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tabLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            app:tabIndicatorColor="#3A7D44"
            app:tabTextColor="#888888"
            app:tabSelectedTextColor="#3A7D44"
            app:tabIndicatorFullWidth="false"
            app:tabRippleColor="@null">

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Plantas Individuales"/>

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Grupos de Plantas"/>

    </com.google.android.material.tabs.TabLayout>

        <!-- CHIPS -->
        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroupFiltro"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="start"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            app:singleSelection="true"
            app:selectionRequired="true"
            app:chipSpacing="8dp">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipTodas"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Todas"
                android:checked="true"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                app:chipBackgroundColor="@color/chip_selector"
                android:textColor="@color/chip_text_selector"
                app:chipStrokeColor="@color/chip_stroke_selector"
                app:chipStrokeWidth="1dp"
                app:checkedIconVisible="false"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/chipProximas"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Próximas"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                app:chipBackgroundColor="@color/chip_selector"
                android:textColor="@color/chip_text_selector"
                app:chipStrokeColor="@color/chip_stroke_selector"
                app:chipStrokeWidth="1dp"
                app:checkedIconVisible="false"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/chipVencidas"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Vencidas"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                app:chipBackgroundColor="@color/chip_selector"
                android:textColor="@color/chip_text_selector"
                app:chipStrokeColor="@color/chip_stroke_selector"
                app:chipStrokeWidth="1dp"
                app:checkedIconVisible="false"/>

        </com.google.android.material.chip.ChipGroup>

        <!-- DIVISOR -->
        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:background="#E0EAD8"/>

        <!-- LISTA -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvPlantas"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingTop="8dp"
            android:paddingBottom="55dp"
            android:clipToPadding="false"/>

    </LinearLayout>

    <!-- FAB -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabPrincipal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="90dp"
        android:contentDescription="Opciones de carga"
        android:src="@android:drawable/ic_input_add"
        app:backgroundTint="#3A7D44"
        app:tint="@android:color/white"
        app:fabSize="normal"
        app:elevation="4dp"
        app:shapeAppearanceOverlay="@style/ShapeAppearance.FAB.Rounded"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>