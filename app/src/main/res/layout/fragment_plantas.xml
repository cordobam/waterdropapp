<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F1F8E9"
    android:paddingBottom="80dp">

    <!-- HEADER -->
    <TextView
        android:id="@+id/tvPromedio"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🌿 Regar Plantas"
        android:padding="20dp"
        android:textSize="22sp"
        android:textStyle="bold"
        android:background="#C8E6C9"
        android:textColor="#1B5E20"/>

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:tabIndicatorColor="#4CAF50"
        app:tabTextColor="#666"
        app:tabSelectedTextColor="#2E7D32"
        app:tabIndicatorFullWidth="false">

        <com.google.android.material.tabs.TabItem
            android:text="Plantas Individuales" />

        <com.google.android.material.tabs.TabItem
            android:text="Grupos de Plantas" />

    </com.google.android.material.tabs.TabLayout>

    <com.google.android.material.chip.ChipGroup
        android:id="@+id/chipGroupFiltro"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp"
        android:visibility="visible"
        android:gravity="center"
        app:singleSelection="true"
        app:selectionRequired="true"
        app:chipSpacing="8dp">

        <com.google.android.material.chip.Chip
            android:id="@+id/chipTodas"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Todas"
            android:checked="true"
            style="@style/Widget.MaterialComponents.Chip.Choice"
            app:chipBackgroundColor="@color/chip_selector"
            app:checkedIconVisible="false"/>

        <com.google.android.material.chip.Chip
            android:id="@+id/chipProximas"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Próximas"
            style="@style/Widget.MaterialComponents.Chip.Choice"
            app:chipBackgroundColor="@color/chip_selector"
            app:checkedIconVisible="false"/>

        <com.google.android.material.chip.Chip
            android:id="@+id/chipVencidas"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Vencidas"
            style="@style/Widget.MaterialComponents.Chip.Choice"
            app:chipBackgroundColor="@color/chip_selector"
            app:checkedIconVisible="false"/>

    </com.google.android.material.chip.ChipGroup>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvPlantas"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

</LinearLayout>