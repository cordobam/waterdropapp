<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    app:cardElevation="0dp"
    app:cardCornerRadius="16dp"
    app:strokeColor="#C8DFC0"
    app:strokeWidth="1dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <!-- ÍCONO GRUPO -->
        <FrameLayout
            android:id="@+id/iconGrupo"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_circle_green_light"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="center"
                android:src="@android:drawable/ic_menu_agenda"
                app:tint="#3A7D44"/>

        </FrameLayout>

        <!-- NOMBRE -->
        <TextView
            android:id="@+id/tvNombreGrupoAct"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Grupo Jardín"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#1A3A1F"
            android:layout_marginStart="12dp"
            app:layout_constraintStart_toEndOf="@id/iconGrupo"
            app:layout_constraintEnd_toStartOf="@id/btnActualizarGrupo"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

        <!-- BTN EDITAR -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnActualizarGrupo"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Editar"
            android:textSize="12sp"
            android:textColor="#3A7D44"
            app:strokeColor="#3A7D44"
            app:strokeWidth="1.5dp"
            app:cornerRadius="10dp"
            android:layout_marginEnd="6dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btnEliminarGrupo"/>

        <!-- BTN ELIMINAR -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnEliminarGrupo"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="36dp"
            android:layout_height="36dp"
            app:icon="@android:drawable/ic_menu_delete"
            app:iconSize="18dp"
            app:iconTint="#E53935"
            app:strokeColor="#FFCDD2"
            app:strokeWidth="1.5dp"
            app:cornerRadius="10dp"
            app:iconPadding="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>